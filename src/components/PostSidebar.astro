---
/**
 * 文章左侧 sticky 边栏
 * - 顶部：返回链接
 * - 中部：文章目录（吸顶）
 * - 底部：作者卡 / 文章元信息
 */
import Icon from './Icon.astro'

export interface Heading {
  depth: number
  slug: string
  text: string
}

export interface Props {
  headings: Heading[]
  dateStr: string
  readingLabel: string
  chars: number
  updatedStr?: string
  tags: { id: string; name: string; color: string }[]
}

const { headings, dateStr, readingLabel, chars, updatedStr, tags } = Astro.props
const tocItems = headings.filter((h) => h.depth === 2 || h.depth === 3)
---

<aside class="hidden xl:block sticky top-24 self-start max-h-[calc(100vh-7rem)] overflow-y-auto pr-2 text-sm">
  <!-- 顶部：返回列表 -->
  <a
    href="/posts"
    class="inline-flex items-center gap-1 text-gray-500 hover:text-brand-600 transition-colors mb-6"
  >
    <Icon name="arrow-left" size={14} />
    返回列表
  </a>

  <!-- 目录 -->
  {tocItems.length > 0 && (
    <div class="mb-6">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3 flex items-center gap-1.5">
        <Icon name="format-list-bulleted" size={12} class="text-brand-600" />
        文章目录
      </h2>
      <nav id="toc" aria-label="文章目录">
        <ul class="space-y-1 border-l border-gray-200 dark:border-gray-800">
          {tocItems.map((h) => (
            <li>
              <a
                href={`#${h.slug}`}
                data-toc-link={h.slug}
                class:list={[
                  'toc-link block pl-3 py-1 -ml-px border-l-2 border-transparent text-gray-600 dark:text-gray-400 hover:text-brand-600 hover:border-brand-500 transition-colors',
                  h.depth === 3 && 'pl-6 text-xs',
                ]}
              >
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  )}

  <!-- 文章元信息 -->
  <div class="pt-4 border-t border-gray-200 dark:border-gray-800 space-y-2 text-xs text-gray-500">
    <div class="flex items-center gap-1.5">
      <Icon name="calendar" size={12} class="text-brand-600" />
      <span>{dateStr}</span>
    </div>
    <div class="flex items-center gap-1.5">
      <Icon name="clock" size={12} class="text-brand-600" />
      <span>预计阅读 {readingLabel}</span>
    </div>
    <div class="flex items-center gap-1.5">
      <Icon name="text" size={12} class="text-brand-600" />
      <span>{chars.toLocaleString()} 字</span>
    </div>
    {updatedStr && (
      <div class="flex items-center gap-1.5">
        <Icon name="pencil" size={12} class="text-brand-600" />
        <span>更新于 {updatedStr}</span>
      </div>
    )}
  </div>

  <!-- 标签列表（侧栏版本） -->
  {tags.length > 0 && (
    <div class="pt-4 mt-4 border-t border-gray-200 dark:border-gray-800">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">标签</h3>
      <div class="flex flex-wrap gap-1.5">
        {tags.map((t) => (
          <a
            href={`/tags/${t.id}`}
            class="inline-block px-2 py-0.5 rounded text-[11px] hover:opacity-80 transition-opacity"
            style={`background-color: ${t.color}20; color: ${t.color};`}
          >
            {t.name}
          </a>
        ))}
      </div>
    </div>
  )}
</aside>

<script>
  function initToc() {
    const toc = document.getElementById('toc')
    if (!toc) return

    const links = toc.querySelectorAll<HTMLAnchorElement>('a[data-toc-link]')
    const map = new Map<string, HTMLAnchorElement>()
    links.forEach((l) => map.set(l.dataset.tocLink!, l))

    const headings = Array.from(map.keys())
      .map((slug) => document.getElementById(slug))
      .filter((el): el is HTMLElement => Boolean(el))

    if (headings.length === 0) return

    function activate(slug: string | null) {
      links.forEach((l) => {
        l.classList.remove('text-brand-600', 'border-brand-500', 'font-medium')
        l.classList.add('border-transparent')
      })
      if (slug && map.has(slug)) {
        const link = map.get(slug)!
        link.classList.add('text-brand-600', 'border-brand-500', 'font-medium')
        link.classList.remove('border-transparent')
      }
    }

    let currentSlug: string | null = null
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            currentSlug = entry.target.id
            activate(currentSlug)
          }
        })
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
    )
    headings.forEach((h) => observer.observe(h))

    links.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault()
        const slug = link.dataset.tocLink!
        const target = document.getElementById(slug)
        if (!target) return
        const top = target.getBoundingClientRect().top + window.scrollY - 80
        window.scrollTo({ top, behavior: 'smooth' })
        history.pushState(null, '', `#${slug}`)
        activate(slug)
      })
    })

    if (location.hash) activate(location.hash.slice(1))
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initToc)
  } else {
    initToc()
  }
</script>
