---
/**
 * Icon 组件（Astro 版本）
 * 底层用 astro-icon 渲染 Iconify SVG 集合
 * - 服务端渲染：零运行时 JS
 * - 1.5 万+ 图标可选（lucide / simple-icons / material / heroicons 等）
 * - 自动按需内联 SVG（构建时）
 *
 * 用法：
 *   <Icon name="search" />             <!-- 默认 lucide -->
 *   <Icon name="github" />             <!-- 自动映射 simple-icons -->
 *   <Icon name="material:home" />     <!-- 显式指定集合 -->
 */
import { Icon as IconifyIcon } from 'astro-icon/components'

// 品牌图标 → simple-icons
const BRAND_ICONS: Record<string, true> = { github: true }

export type IconName =
  | 'alert-circle'
  | 'arrow-left'
  | 'arrow-right'
  | 'book-open'
  | 'bot'
  | 'calendar'
  | 'check'
  | 'chevron-down'
  | 'chevron-up'
  | 'clock'
  | 'close'
  | 'copy'
  | 'counter'
  | 'delete-sweep'
  | 'file-document-multiple'
  | 'file-search'
  | 'file-search-outline'
  | 'format-list-bulleted'
  | 'github'
  | 'home'
  | 'link-variant'
  | 'loading'
  | 'map'
  | 'menu'
  | 'moon'
  | 'pencil'
  | 'refresh'
  | 'rss'
  | 'search'
  | 'send'
  | 'sitemap'
  | 'stop'
  | 'sun'
  | 'tag-multiple'
  | 'tag'
  | 'text'
  | 'text-search'
  | 'weather-night'
  | 'weather-sunny'
  | 'x'

export interface Props {
  name: IconName
  size?: number
  class?: string
}

const { name, size = 18, class: className = '' } = Astro.props
// 命名空间映射：品牌图标在 simple-icons，其他默认 lucide
const iconName = name.includes(':')
  ? name
  : BRAND_ICONS[name]
    ? `simple-icons:${name}`
    : `lucide:${name}`
---

<IconifyIcon
  name={iconName}
  size={size}
  class={className}
  aria-hidden="true"
/>
