---
/**
 * Icon 组件（Astro 版本）
 * 底层用 astro-icon 渲染 Iconify SVG 集合
 * - 服务端渲染：零运行时 JS
 * - 1.5 万+ 图标可选
 *
 * 用法：
 *   <Icon name="search" class="text-lg" />
 *   <Icon name="arrow-right" size={20} />
 */
import { Icon } from 'astro-icon/components'

export type IconName = 'alert-circle' | 'arrow-left' | 'arrow-right' | 'book-open' | 'bot' | 'calendar' | 'check' | 'chevron-down' | 'chevron-up' | 'clock' | 'close' | 'copy' | 'counter' | 'delete-sweep' | 'file-document-multiple' | 'file-search' | 'file-search-outline' | 'format-list-bulleted' | 'github' | 'home' | 'link-variant' | 'loading' | 'menu' | 'moon' | 'pencil' | 'refresh' | 'rss' | 'search' | 'send' | 'sitemap' | 'stop' | 'sun' | 'tag-multiple' | 'tag' | 'text' | 'text-search' | 'weather-night' | 'weather-sunny' | 'x'

export interface Props {
  name: IconName
  size?: number
  class?: string
  strokeWidth?: number
}

const { name, size = 18, class: className = '', strokeWidth = 2 } = Astro.props
// 命名空间映射：github 在 simple-icons，其他默认 lucide
const iconName =
  name.includes(':') ? name : name === 'github' ? 'simple-icons:github' : `lucide:${name}`
---

<Icon name={iconName} size={size} class={className} aria-hidden="true" />
