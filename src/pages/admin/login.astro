---
export const prerender = false
import BaseLayout from '../../layouts/BaseLayout.astro'
import Icon from '../../components/Icon.astro'
import { isAdminConfigured } from '../../lib/admin-auth'

const url = Astro.url
const error = url.searchParams.get('error')
const redirect = url.searchParams.get('redirect') || '/admin/errors'
const notConfigured = !isAdminConfigured()
---

<BaseLayout title="Admin 登录" description="管理后台登录">
  <main class="min-h-[80vh] flex items-center justify-center px-4">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <Icon name="bot" size={40} class="text-brand-600 inline-block mb-3" />
        <h1 class="text-2xl font-bold">管理后台</h1>
        <p class="text-sm text-gray-500 mt-1">请输入管理员密码</p>
      </div>

      <form method="POST" action="/admin/login" class="space-y-4">
        <input type="hidden" name="redirect" value={redirect} />
        <div>
          <input
            type="password"
            name="password"
            autofocus
            required
            placeholder="密码"
            disabled={notConfigured}
            class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-500 disabled:opacity-50"
          />
        </div>

        {notConfigured && (
          <p class="text-sm text-amber-600 flex items-start gap-1">
            <Icon name="alert-circle" size={14} class="flex-shrink-0 mt-0.5" />
            <span>后台未配置：请在 <code class="px-1 bg-gray-100 dark:bg-gray-800 rounded">.env</code> 同时设置 <code>ADMIN_PASSWORD</code> 和 <code>ADMIN_SECRET</code></span>
          </p>
        )}

        {error && !notConfigured && (
          <p class="text-sm text-red-600 flex items-center gap-1">
            <Icon name="alert-circle" size={14} />
            {error === 'invalid' ? '密码错误' : '登录失败'}
          </p>
        )}

        <button type="submit" class="btn-primary w-full" disabled={notConfigured}>
          {notConfigured ? '未配置' : '登录'}
        </button>
      </form>

      <p class="text-xs text-gray-400 text-center mt-6">
        密码与签名密钥在 <code class="px-1 bg-gray-100 dark:bg-gray-800 rounded">.env</code> 的 <code>ADMIN_PASSWORD</code> / <code>ADMIN_SECRET</code>
      </p>
    </div>
  </main>
</BaseLayout>
