---
export const prerender = true
import BaseLayout from '../layouts/BaseLayout.astro'
import Icon from '../components/Icon.astro'
---

<BaseLayout title="404" description="页面未找到">
  <section class="max-w-2xl mx-auto px-4 py-24 text-center">
    <h1 class="text-6xl font-bold text-brand-600 mb-4">404</h1>
    <p class="text-2xl mb-6">页面未找到</p>
    <p class="text-gray-600 dark:text-gray-400 mb-8">
      你访问的页面不存在或已被移动。
    </p>
    <a href="/" class="btn-primary">
      <Icon name="home" size={16} class="mr-1" />
      回到首页
    </a>
  </section>
</BaseLayout>
