# 站点基础配置
SITE_URL=https://yourblog.com
SITE_TITLE=My Blog
SITE_DESCRIPTION=记录 · 分享 · 思考
SITE_AUTHOR=yourname

# 社交链接
GITHUB_URL=https://github.com/yourname
TWITTER_URL=

# ──────────────── AI 配置（LM Studio） ────────────────
# LM Studio 默认 OpenAI 兼容服务地址
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LM Studio 不校验 key，留默认即可
LMSTUDIO_API_KEY=lm-studio
# LLM 模型名（用于对话生成）
LMSTUDIO_MODEL=local-model
# Embedding 模型名（用于 RAG 向量检索）
# 留空 → 降级到关键词检索
# 推荐: text-embedding-nomic-embed-text-v1.5
EMBEDDING_MODEL=

# ──────────────── Embedding 服务（可独立配置远程） ────────────────
# 留空 = 复用上面的 LMSTUDIO_BASE_URL
# 例如远程电脑跑 embedding 服务：EMBEDDING_BASE_URL=http://192.168.1.100:1235/v1
EMBEDDING_BASE_URL=
# 远程服务如需鉴权
EMBEDDING_API_KEY=

# RAG 检索返回的片段数
RAG_TOP_K=4
# 余弦相似度阈值（0-1），低于此分数的片段不进入上下文
RAG_MIN_SCORE=0.3

# ──────────────── CSDN 自动发布 ────────────────
CSDN_COOKIE=
CSDN_CATEGORY=前端

# ──────────────── 掘金自动发布 ────────────────
JUEJIN_COOKIE=
JUEJIN_CATEGORY_ID=6809637767543259144
JUEJIN_TAG_IDS=

# ──────────────── 错误监控后台 ────────────────
# /admin 登录密码（至少 4 位，未配置则后台不可访问）
ADMIN_PASSWORD=
# Session 签名密钥（至少 16 位）。生产环境用 `openssl rand -base64 32` 生成
# 留空 = 后台拒绝访问（fail-secure）
ADMIN_SECRET=

# ──────────────── Umami 隐私分析 ────────────────
# 留空 = 不加载分析脚本（开发/未配置时）
# 云端（免费）：https://cloud.umami.is
# 自托管：你的 Umami 实例 URL（不要带末尾 /）
PUBLIC_UMAMI_URL=
# Website ID（在 Umami 后台 Settings → Websites → 复制）
PUBLIC_UMAMI_ID=
